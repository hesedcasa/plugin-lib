{
  "name": "@hesed/plugin-lib",
  "version": "0.6.0",
  "description": "Shared utilities for Hesed oclif plugins",
  "author": "Hesed",
  "dependencies": {
    "@inquirer/prompts": "^8.2.0",
    "@oclif/core": "^4",
    "@toon-format/toon": "^2.1.0",
    "fs-extra": "^11.3.3"
  },
  "devDependencies": {
    "@eslint/compat": "^2",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^5.2.3",
    "@types/fs-extra": "^11.0.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25",
    "@types/sinon": "^21.0.1",
    "chai": "^6.2.2",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^11",
    "oclif": "^4",
    "prettier": "^3.8.1",
    "shx": "^0.4.0",
    "sinon": "^22.0.0",
    "ts-node": "^10.9.2",
    "ts-prune": "^0.10.3",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "./dist"
  ],
  "homepage": "https://github.com/hesedcasa/plugin-lib",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "commands": "./dist/commands",
    "topicSeparator": " "
  },
  "repository": "hesedcasa/plugin-lib",
  "scripts": {
    "build": "shx rm -rf dist tsconfig.tsbuildinfo && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "test:coverage": "c8 npm test",
    "test:coverage:report": "c8 --reporter=html --reporter=text npm test",
    "version": "oclif readme && git add README.md",
    "find-deadcode": "ts-prune --ignore '(run|default)'",
    "format": "eslint --cache --fix --quiet . && prettier --write --cache .",
    "pre-commit": "npm run format && npm run find-deadcode"
  },
  "types": "dist/index.d.ts"
}
